    print(f"  메타:   {len(meta_data)}일")
    print(f"  밴스드: {len(vanced_data)}일")
    print(f"  네이버: {len(naver_google.get('naver_ads', {}))}일")
    print(f"  구글:   {len(naver_google.get('google_ads', {}))}일")

    ss = gc.open_by_url(URL_CH_OUTPUT)
    start = datetime.strptime(CH_START_DATE, "%Y-%m-%d").date()
    end   = datetime.strptime(CH_END_DATE, "%Y-%m-%d").date()
    dates = []; d = end
    while d >= start: dates.append(d); d -= timedelta(days=1)
    nd = len(dates)

    sun_cols = []; dh = []
    for i, dt in enumerate(dates):
        wd = WD[dt.weekday()]; dh.append(f"{dt.month:02d}/{dt.day:02d}({wd})")
        if dt.weekday() == 6: sun_cols.append(3+i)
    r7 = dates[:7] if len(dates) >= 7 else dates
    na = naver_google.get('naver_ads', {})
    ga = naver_google.get('google_ads', {})

    def total_spend(dt):
