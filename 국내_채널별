    rules=[
        (f'{ve}=0',                       {"red":1,"green":0.6,"blue":0.6}),
        (f'{ve}>=300',                     {"red":0.6,"green":1,"blue":1}),
        (f'AND({ve}>=200,{ve}<300)',       {"red":0.7,"green":1,"blue":0.7}),
        (f'AND({ve}>=100,{ve}<200)',       {"red":1,"green":1,"blue":0.6}),
        (f'AND({ve}<100,{ve}>0)',          {"red":1,"green":0.8,"blue":0.8}),
    ]
    cr=[{"addConditionalFormatRule":{"rule":{"ranges":[{"sheetId":sid,"startRowIndex":1,"endRowIndex":tdr,"startColumnIndex":3,"endColumnIndex":nc}],"booleanRule":{"condition":{"type":"CUSTOM_FORMULA","values":[{"userEnteredValue":rf(c)}]},"format":{"backgroundColor":bg}}},"index":0}} for c,bg in rules]
    with_retry(ss.batch_update, body={"requests":cr}); time.sleep(3)

    print("  🎨 텍스트 색상...")
    txr=[]
    for ci in range(3,nc):
        try: cv=with_retry(ws.col_values,ci+1)
        except: continue
        if not cv or len(cv)<2: continue
        for ri in range(1,min(len(cv),tdr)):
            val=cv[ri]
            if not val or '\n' not in val: continue
            lines_val=val.split('\n')
            if len(lines_val)<3: continue
            l1e=len(lines_val[0]); l2e=l1e+1+len(lines_val[1]); l3e=l2e+1+len(lines_val[2])
            runs=[{"startIndex":0,"format":BK},{"startIndex":l1e+1,"format":GN},{"startIndex":l2e+1,"format":BK}]
            if len(lines_val)>=4: runs.append({"startIndex":l3e+1,"format":RD})
            txr.append({"updateCells":{"range":{"sheetId":sid,"startRowIndex":ri,"endRowIndex":ri+1,"startColumnIndex":ci,"endColumnIndex":ci+1},"rows":[{"values":[{"userEnteredValue":{"stringValue":val},"textFormatRuns":runs}]}],"fields":"userEnteredValue,textFormatRuns"}})
            if len(txr)>=300:
                try: with_retry(ss.batch_update,body={"requests":txr}); txr=[]; time.sleep(3)
                except: txr=[]
    if txr:
        try: with_retry(ss.batch_update,body={"requests":txr}); time.sleep(2)
        except: pass

    print(f"\n  ✅ '{CH_SHEET_NAME}' 완성!")


