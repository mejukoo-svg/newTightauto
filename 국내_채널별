def retry_api(func, *args, retries=4, base_delay=2, **kwargs):
    for attempt in range(retries):
        try:
            return func(*args, **kwargs)
        except gspread.exceptions.APIError as e:
            status = e.response.status_code if hasattr(e, 'response') else 0
            if status in (429, 500, 502, 503) and attempt < retries - 1:
                wait = base_delay * (2 ** attempt)
                print(f"    ⏳ API {status}, {wait}초 후 재시도 ({attempt+1}/{retries})...")
                time.sleep(wait)
            else:
                raise
        except Exception as e:
            if attempt < retries - 1:
                wait = base_delay * (2 ** attempt)
                print(f"    ⏳ 오류 발생, {wait}초 후 재시도 ({attempt+1}/{retries}): {e}")
                time.sleep(wait)
            else:
                raise

def retry_batch_update(sp, body, retries=4, base_delay=2):
    return retry_api(sp.batch_update, body=body, retries=retries, base_delay=base_delay)

def with_retry(fn, *a, max_retries=5, **kw):
    """채널별 추이차트용 retry 래퍼 — ★ 수정: 마지막 retry 실패 시 반드시 raise"""
    last_err = None
    for i in range(max_retries):
        try:
            return fn(*a, **kw)
        except Exception as e:
            last_err = e
            if "429" in str(e) or "Quota" in str(e):
                wait = 15 + i * 10
                print(f"    ⏳ Quota/429, {wait}초 대기 ({i+1}/{max_retries})...")
                time.sleep(wait)
            elif i == max_retries - 1:
                raise
            else:
                time.sleep(3)
    # ★ 핵심 수정: 429로 모든 retry 소진 시에도 raise
    if last_err is not None:
        raise last_err

def safe_float(v):
    try:
        f = float(v)
        return 0 if (math.isnan(f) or math.isinf(f)) else f
    except:
        return 0

def safe_int(v):
    return int(safe_float(v))

def clean_for_json(val):
    if val is None: return ''
    if isinstance(val, (np.integer,)): return int(val)
    if isinstance(val, (np.floating, float)):
        v = float(val)
        return '' if (math.isnan(v) or math.isinf(v)) else v
    return val

def _num(x):
    """채널별 추이차트용 숫자 파싱"""
    try:
        v = str(x).replace(",","").replace("₩","").replace("%","").replace("\\","").replace("W","").replace("￦","").replace("+","").strip()
        return float(v) if v and v not in ["-","#DIV/0!","","nan","None","NaN"] else 0.0
    except:
        return 0.0

def money(n):
    try: return f"₩{int(round(float(n))):,}"
    except: return "₩0"

def _infer_year(month):
    """
    ★ Colab 버전과 동일한 연도 추론 로직
    현재 날짜 기준으로 적절한 연도를 추론합니다.
    예: 현재 2026년 3월이면, month <= 3 → 2026, month > 3 → 2025
    """
    today = date.today()
    # 현재 월 이하의 월은 올해, 이후 월은 작년
    if month <= today.month:
        return today.year
    else:
        return today.year - 1

def parse_date(raw):
    """시트 날짜 형식 파서 (멀티라인 헤더 대응) — ★ 연도 추론 수정"""
    raw = str(raw).strip()
    if not raw or raw in ['', 'nan', 'None']:
        return None
    raw = raw.split('\n')[0].strip()

    # 1) 'YY/M/D(요일)': '26/03/18(수)'
    m = re.match(r'^(\d{2})/(\d{1,2})/(\d{1,2})', raw)
    if m:
        try: return date(2000 + int(m.group(1)), int(m.group(2)), int(m.group(3)))
        except: pass

    # 2) 'MM/DD (요일)': '03/01 (일)' — ★ _infer_year 사용
    m = re.match(r'^(\d{1,2})/(\d{1,2})\s+\(', raw)
    if m:
        month, day = int(m.group(1)), int(m.group(2))
        year = _infer_year(month)
        try: return date(year, month, day)
        except: return None

    # 3) 'M/D': '3/18', '03/01' — ★ _infer_year 사용
    m = re.match(r'^(\d{1,2})/(\d{1,2})(?:\s*$|\s*[\(\[])', raw)
    if m:
        month, day = int(m.group(1)), int(m.group(2))
        year = _infer_year(month)
        try: return date(year, month, day)
        except: return None

    # 4) 'YY-MM-DD': '26-03-10'
    m = re.match(r'^(\d{2})-(\d{1,2})-(\d{1,2})$', raw)
    if m:
        try: return date(2000 + int(m.group(1)), int(m.group(2)), int(m.group(3)))
        except: return None

    # 5) 'YY/MM/DD': '26/03/12'
    m = re.match(r'^(\d{2})/(\d{1,2})/(\d{1,2})$', raw)
    if m:
        try: return date(2000 + int(m.group(1)), int(m.group(2)), int(m.group(3)))
        except: return None

    # 6) 'YYYY-MM-DD' etc
    for fmt in ["%Y-%m-%d %H:%M:%S", "%Y-%m-%d", "%Y/%m/%d"]:
        try: return datetime.strptime(raw[:19 if 'H' in fmt else 10], fmt).date()
        except: pass

    return None


