        nav  = na.get(dt, {}).get('spend', 0)
        goo  = ga.get(dt, {}).get('spend', 0)
        return base + nav + goo

    channels = [
        {
            'name': '전체',
            'get_rev':   lambda dt: total_daily.get(dt, {}).get('revenue', 0),
            'get_spend': lambda dt: total_spend(dt),
        },
        {
            'name': '메타',
            'get_rev':   lambda dt: meta_data.get(dt, {}).get('revenue', 0),
            'get_spend': lambda dt: meta_data.get(dt, {}).get('spend', 0),
        },
        {
            'name': '밴스드',
            'get_rev':   lambda dt: vanced_data.get(dt, {}).get('revenue', 0),
            'get_spend': lambda dt: vanced_data.get(dt, {}).get('spend', 0),
