def ch_cell_text(revenue, spend):
    """채널별 추이차트용 셀 텍스트"""
    if spend == 0 and revenue == 0: return ""
    roas = (revenue / spend * 100) if spend > 0 else 0
    profit = revenue - spend
    return f"{roas:.0f}\n{money(profit)}\n{money(revenue)}\n-{money(spend)}"

def ch_fmt_req(sid, sr, er, sc, ec, fmt):
    return {"repeatCell":{"range":{"sheetId":sid,"startRowIndex":sr,"endRowIndex":er,"startColumnIndex":sc,"endColumnIndex":ec},"cell":{"userEnteredFormat":fmt},"fields":"userEnteredFormat"}}

def ch_border_req(sid, sr, er, sc, ec):
    bs={"style":"SOLID","width":1,"color":{"red":0.7,"green":0.7,"blue":0.7}}
    return {"updateBorders":{"range":{"sheetId":sid,"startRowIndex":sr,"endRowIndex":er,"startColumnIndex":sc,"endColumnIndex":ec},"top":bs,"bottom":bs,"left":bs,"right":bs,"innerHorizontal":bs,"innerVertical":bs}}


# ── 소스1: 전체 매출/지출 ──
def fetch_total_daily():
    print("\n" + "="*60)
    print("📊 [소스1] 전체 매출/지출")
    print("="*60)

    ss = gc.open_by_url(URL_TOTAL)
    ws = None
    for s in ss.worksheets():
        if s.id == GID_TOTAL: ws = s; break
    if ws is None:
        print("  ⚠️ gid 시트 못 찾음"); return {}

    print(f"  📖 시트: {ws.title}")
    vals = with_retry(ws.get_all_values); time.sleep(1)
    if not vals or len(vals) < 2:
        print("  ⚠️ 데이터 없음"); return {}

    date_col = 4; rev_col = 5; spend_col = 12
    start_d = datetime.strptime(CH_START_DATE, "%Y-%m-%d").date()
    end_d   = datetime.strptime(CH_END_DATE, "%Y-%m-%d").date()
    daily = {}

    for ri in range(1, len(vals)):
        row = vals[ri]
        if date_col >= len(row): continue
        dt = parse_date(row[date_col])
        if dt is None or dt < start_d or dt > end_d: continue
        rev   = _num(row[rev_col])   if rev_col   < len(row) else 0
        spend = _num(row[spend_col]) if spend_col < len(row) else 0
        if dt not in daily: daily[dt] = {'revenue':0.0, 'spend':0.0}
        daily[dt]['revenue'] += rev
        daily[dt]['spend']   += spend

    # ★ Colab 버전과 동일하게 일별 상세 로그 추가
    for dt in sorted(daily):
        rv, sp = daily[dt]['revenue'], daily[dt]['spend']
        if sp > 0:
            print(f"  {dt}  매출 ₩{rv:>14,.0f}  지출 ₩{sp:>14,.0f}  ROAS {rv/sp:.2f}")
        else:
            print(f"  {dt}  매출 ₩{rv:>14,.0f}")

    ts = sum(d['spend'] for d in daily.values())
    tr = sum(d['revenue'] for d in daily.values())
    if ts > 0:
        print(f"  합계   매출 ₩{tr:>14,.0f}  지출 ₩{ts:>14,.0f}  ROAS {tr/ts:.2f}")
    print(f"  → {len(daily)}일 데이터")
    return daily


# ── 소스2: 네이버/구글 ──
def fetch_naver_google():
    print("\n" + "="*60)
    print("📊 [소스2] 네이버/구글 Daily 탭")
    print("="*60)

    ss = gc.open_by_url(URL_NAV_GOO)
    ws = None
    for s in ss.worksheets():
        if NAV_GOO_DAILY_TAB in s.title or s.title.strip() == NAV_GOO_DAILY_TAB:
            ws = s; break
    if ws is None:
        for s in ss.worksheets():
            if '네이버' in s.title and 'Daily' in s.title: ws = s; break
    if ws is None:
        print(f"  ⚠️ 탭 못 찾음"); return {}

    print(f"  📖 시트: {ws.title}")
    vals = with_retry(ws.get_all_values); time.sleep(1)
    if not vals or len(vals) < 3:
        print("  ⚠️ 데이터 없음"); return {}

    gh = [str(v).strip() for v in vals[0]]
    ch = [str(v).strip() for v in vals[1]]

    groups = {}; cg = None
    for ci, val in enumerate(gh):
        if val and val not in ['', 'nan']: cg = val; groups[cg] = {'start': ci, 'end': len(ch)}
    sg = sorted(groups.items(), key=lambda x: x[1]['start'])
    for i, (gn, gi) in enumerate(sg):
        if i + 1 < len(sg): gi['end'] = sg[i+1][1]['start']

    nsc = nrc = gsc = grc = None
    for gn, gi in groups.items():
        for ci in range(gi['start'], min(gi['end'], len(ch))):
            h = ch[ci]
            if '네이버' in gn or '파워링크' in gn:
                if h == '총 지출':       nsc = ci
                elif h == '총 구매전환값': nrc = ci
            elif '구글' in gn or '검색' in gn:
                if h == '총 지출':       gsc = ci
                elif h in ['구매전환값', '총 구매전환값']: grc = ci

    print(f"  → 네이버: 지출=col{nsc}, 매출=col{nrc}")
    print(f"  → 구글:   지출=col{gsc}, 매출=col{grc}")

    start_d = datetime.strptime(CH_START_DATE, "%Y-%m-%d").date()
    end_d   = datetime.strptime(CH_END_DATE, "%Y-%m-%d").date()
    result = {
        'naver_ads': defaultdict(lambda:{'spend':0.0,'revenue':0.0}),
        'google_ads': defaultdict(lambda:{'spend':0.0,'revenue':0.0}),
    }

    for ri in range(2, len(vals)):
        row = vals[ri]
        if not row or len(row) < 1: continue
        dt = parse_date(row[0])
        if dt is None or dt < start_d or dt > end_d: continue
        if nsc is not None and nsc < len(row): result['naver_ads'][dt]['spend']   += _num(row[nsc])
        if nrc is not None and nrc < len(row): result['naver_ads'][dt]['revenue'] += _num(row[nrc])
        if gsc is not None and gsc < len(row): result['google_ads'][dt]['spend']   += _num(row[gsc])
        if grc is not None and grc < len(row): result['google_ads'][dt]['revenue'] += _num(row[grc])

    for cn, cd in result.items():
        ts = sum(d['spend'] for d in cd.values()); tr = sum(d['revenue'] for d in cd.values())
        if ts > 0:
            print(f"  {cn}: 지출 ₩{ts:>10,.0f}  매출 ₩{tr:>10,.0f}  ROAS {tr/ts:.2f}")
        else:
            print(f"  {cn}: 데이터 없음")
    return dict(result)


# ── 추이차트 Row2 종합 공통 파서 ──
def _fetch_trend_row2(url, gid, label, line_config):
    """
    line_config:
      'meta'   → line[0]=구매수, line[1]=순이익, line[2]=지출(음수)
                  매출 = abs(지출) + 순이익
      'vanced' → line[0]=구매수, line[1]=순이익, line[2]=매출, line[3]=지출
                  ★ 지출은 양수/음수 모두 가능 → abs() 처리
    """
    print(f"\n" + "="*60)
    print(f"📊 [{label}]")
    print("="*60)

    ss = gc.open_by_url(url)
    ws = None
    for s in ss.worksheets():
        if s.id == gid: ws = s; break
    if ws is None:
        for s in ss.worksheets():
            if '추이차트' in s.title and '주간' not in s.title: ws = s; break
    if ws is None:
        print("  ⚠️ 추이차트 탭 못 찾음"); return {}

    print(f"  📖 시트: {ws.title}")
    vals = with_retry(ws.get_all_values); time.sleep(1)
    if not vals or len(vals) < 2:
        print("  ⚠️ 빈 시트"); return {}

    headers = vals[0]
    row2 = vals[1]

    print(f"  → 전체 컬럼 수: {len(headers)}")
    for ci in range(min(8, len(headers))):
        print(f"    col{ci}: {repr(headers[ci])}")

    date_start_col = None
    for ci in range(len(headers)):
        dt = parse_date(headers[ci])
        if dt is not None:
            date_start_col = ci
            print(f"  → 날짜 시작: col{ci} = {repr(headers[ci])} → {dt}")
            break

    if date_start_col is None:
        print("  ⚠️ 날짜 컬럼 못 찾음!")
        print(f"  → 헤더 전체: {[repr(h) for h in headers[:15]]}")
        return {}

    first_cell = str(row2[date_start_col]) if date_start_col < len(row2) else ""
    first_lines = first_cell.split('\n')
    print(f"  → 파싱 모드: {line_config}")
    print(f"  → 첫 셀 (col{date_start_col}) 라인수={len(first_lines)}:")
    for li, l in enumerate(first_lines):
        print(f"    line[{li}] = {repr(l)}")

    start_d = datetime.strptime(CH_START_DATE, "%Y-%m-%d").date()
    end_d   = datetime.strptime(CH_END_DATE, "%Y-%m-%d").date()
    daily = {}
    parsed_count = 0
    skip_count = 0

    for ci in range(date_start_col, len(headers)):
        dt = parse_date(headers[ci])
        if dt is None:
            skip_count += 1; continue
        if dt < start_d or dt > end_d: continue

        cell = str(row2[ci]) if ci < len(row2) else ""
        if not cell.strip(): continue
        lines = [l.strip() for l in cell.split('\n')]

        if line_config == 'meta':
            raw_spend = _num(lines[2]) if len(lines) > 2 else 0
            spend = abs(raw_spend)
            profit = _num(lines[1]) if len(lines) > 1 else 0
            revenue = spend + profit
        elif line_config == 'vanced':
            revenue = abs(_num(lines[2])) if len(lines) > 2 else 0
            raw_spend = _num(lines[3]) if len(lines) > 3 else 0
            spend = abs(raw_spend)
            if spend == 0 and len(lines) <= 3 and len(lines) > 1:
                profit = _num(lines[1])
                spend = max(revenue - profit, 0) if revenue > 0 else 0
        else:
            continue

        if parsed_count < 3:
            print(f"  → {dt}: lines={[repr(l) for l in lines[:5]]} → spend={spend:.0f}, rev={revenue:.0f}")

        if spend > 0 or revenue > 0:
            daily[dt] = {'spend': spend, 'revenue': max(revenue, 0)}
            parsed_count += 1

    if skip_count > 0:
        print(f"  → 날짜 파싱 실패 {skip_count}건 (7일평균 등 비날짜 컬럼)")

    # ★ Colab 버전과 동일하게 일별 상세 로그 추가
    ts = sum(d['spend'] for d in daily.values())
    tr = sum(d['revenue'] for d in daily.values())
    for dt in sorted(daily):
        sp, rv = daily[dt]['spend'], daily[dt]['revenue']
        pf = rv - sp
        if sp > 0:
            print(f"  {dt}  지출 ₩{sp:>12,.0f}  순이익 ₩{pf:>12,.0f}  매출 ₩{rv:>12,.0f}  ROAS {rv/sp*100:.0f}%")
        else:
            print(f"  {dt}  매출 ₩{rv:>12,.0f}")
    if ts > 0:
        print(f"  합계   지출 ₩{ts:>12,.0f}  매출 ₩{tr:>12,.0f}  ROAS {tr/ts*100:.0f}%")
    print(f"  → {len(daily)}일 데이터")
    return daily


