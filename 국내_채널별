        rd={"foregroundColor":{"red":0.85,"green":0,"blue":0}}
        bl={"foregroundColor":{"red":0,"green":0,"blue":0.85}}
        retry_batch_update(sp, body={"requests":[{"updateCells":{"range":{"sheetId":sid,"startRowIndex":1,"endRowIndex":2,"startColumnIndex":2,"endColumnIndex":3},
            "rows":[{"values":[{"userEnteredValue":{"stringValue":C2_LABEL},"textFormatRuns":[
                {"startIndex":idx[0],"format":bk},{"startIndex":idx[1],"format":dg},
                {"startIndex":idx[2],"format":rd},{"startIndex":idx[3],"format":bl},
                {"startIndex":idx[4],"format":bk}]}]}],"fields":"userEnteredValue,textFormatRuns"}}]})
        time.sleep(1)
        print("  ✅ C2 라벨")
    except Exception as e:
        print(f"  ⚠️ C2: {e}")

    print("  🎨 셀 텍스트 색상...")
