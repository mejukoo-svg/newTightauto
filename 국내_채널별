def write_sheet(gc, total_daily, naver_google, meta_data, vanced_data):
    print("\n" + "="*60)
    print(f"📝 '{SHEET_NAME}' 시트 생성")
    print("="*60)

    ss = gc.open_by_url(URL_OUTPUT)
    start = datetime.strptime(START_DATE,"%Y-%m-%d").date()
    end = datetime.strptime(END_DATE,"%Y-%m-%d").date()
    dates = []; d = end
    while d >= start: dates.append(d); d -= timedelta(days=1)
    nd = len(dates)

    sun_cols = []; dh = []
    for i, dt in enumerate(dates):
        wd = WD[dt.weekday()]; dh.append(f"{dt.month:02d}/{dt.day:02d}({wd})")
        if dt.weekday() == 6: sun_cols.append(3+i)
    r7 = dates[:7] if len(dates) >= 7 else dates
    na = naver_google.get('naver_ads',{})
    ga = naver_google.get('google_ads',{})

    def total_spend(dt):
        base = total_daily.get(dt, {}).get('spend', 0)
        nav  = na.get(dt, {}).get('spend', 0)
        goo  = ga.get(dt, {}).get('spend', 0)
        return base + nav + goo

    channels = [
        {
            'name': '전체',
            'get_rev':   lambda dt: total_daily.get(dt, {}).get('revenue', 0),
            'get_spend': lambda dt: total_spend(dt),
        },
        {
            'name': '메타',
            'get_rev':   lambda dt: meta_data.get(dt, {}).get('revenue', 0),
            'get_spend': lambda dt: meta_data.get(dt, {}).get('spend', 0),
        },
        {
            'name': '밴스드',
            'get_rev':   lambda dt: vanced_data.get(dt, {}).get('revenue', 0),
            'get_spend': lambda dt: vanced_data.get(dt, {}).get('spend', 0),
        },
        {
            'name': '네이버',
            'get_rev':   lambda dt: na.get(dt, {}).get('revenue', 0),
            'get_spend': lambda dt: na.get(dt, {}).get('spend', 0),
        },
        {
            'name': '구글',
            'get_rev':   lambda dt: ga.get(dt, {}).get('revenue', 0),
            'get_spend': lambda dt: ga.get(dt, {}).get('spend', 0),
        },
    ]

    nr = 2 + len(channels) + 5; nc = 4 + nd
    try:
        ws = ss.worksheet(SHEET_NAME); ws.clear()
        if ws.row_count < nr: ws.add_rows(nr - ws.row_count)
        if ws.col_count < nc: ws.add_cols(nc - ws.col_count)
    except gspread.exceptions.WorksheetNotFound:
        ws = ss.add_worksheet(SHEET_NAME, nr, nc)
    sid = ws.id

    header = ["채널", "", "라벨", "7일 평균"] + dh

    all_rows = []
    for ch in channels:
        ar = sum(ch['get_rev'](dt) for dt in r7)
        asp = sum(ch['get_spend'](dt) for dt in r7)
        row = [ch['name'], "", ""]
        row.append(cell_text(ar, asp))
        for dt in dates:
            row.append(cell_text(ch['get_rev'](dt), ch['get_spend'](dt)))
        all_rows.append(row)

    all_data = [header] + all_rows
    tdr = len(all_data)
    print(f"  → {tdr}행 × {len(header)}열")
    with_retry(ws.update, values=all_data, range_name="A1", value_input_option="USER_ENTERED")
    print("  ✅ 데이터 기록"); time.sleep(2)

    print("  🎨 서식...")
    fr = []
    fr.append(fmt_req(sid,0,1,0,nc,{"backgroundColor":{"red":0.9,"green":0.9,"blue":0.9},"textFormat":{"bold":True,"fontSize":10},"horizontalAlignment":"CENTER","verticalAlignment":"MIDDLE"}))
    for ci in sun_cols:
        if ci < nc: fr.append(fmt_req(sid,0,1,ci,ci+1,{"backgroundColor":{"red":1,"green":0.85,"blue":0.85},"textFormat":{"bold":True}}))
    fr.append(fmt_req(sid,1,2,0,nc,{"textFormat":{"bold":True}}))
    fr.append({"updateSheetProperties":{"properties":{"sheetId":sid,"gridProperties":{"frozenRowCount":1,"frozenColumnCount":1}},"fields":"gridProperties.frozenRowCount,gridProperties.frozenColumnCount"}})
    fr.append(fmt_req(sid,1,tdr,3,nc,{"wrapStrategy":"WRAP","verticalAlignment":"TOP"}))
    fr.append(fmt_req(sid,1,tdr,0,1,{"textFormat":{"bold":True,"fontSize":10}}))
    for ci,w in [(0,100),(1,40),(2,80)]:
        fr.append({"updateDimensionProperties":{"range":{"sheetId":sid,"dimension":"COLUMNS","startIndex":ci,"endIndex":ci+1},"properties":{"pixelSize":w},"fields":"pixelSize"}})
    for ci in range(3,nc):
        fr.append({"updateDimensionProperties":{"range":{"sheetId":sid,"dimension":"COLUMNS","startIndex":ci,"endIndex":ci+1},"properties":{"pixelSize":100},"fields":"pixelSize"}})
    fr.append(border_req(sid,0,tdr,0,nc))
    with_retry(ss.batch_update, body={"requests":fr}); time.sleep(2)

    BK={"foregroundColor":{"red":0,"green":0,"blue":0}}
    GN={"foregroundColor":{"red":0.22,"green":0.46,"blue":0.11}}
    RD={"foregroundColor":{"red":0.85,"green":0,"blue":0}}

    label="ROAS\n순이익\n매출\n지출"; ln=label.split('\n'); idx=[0]; p=0
    for l in ln[:-1]: p+=len(l)+1; idx.append(p)
    with_retry(ss.batch_update, body={"requests":[{"updateCells":{"range":{"sheetId":sid,"startRowIndex":1,"endRowIndex":2,"startColumnIndex":2,"endColumnIndex":3},"rows":[{"values":[{"userEnteredValue":{"stringValue":label},"textFormatRuns":[{"startIndex":idx[0],"format":BK},{"startIndex":idx[1],"format":GN},{"startIndex":idx[2],"format":BK},{"startIndex":idx[3],"format":RD}]}]}],"fields":"userEnteredValue,textFormatRuns"}}]}); time.sleep(1)

    print("  🎨 ROAS 조건부 서식...")
    ve='VALUE(LEFT(INDIRECT(ADDRESS(ROW(),COLUMN())),FIND(CHAR(10),INDIRECT(ADDRESS(ROW(),COLUMN()))&CHAR(10))-1))'
    rf=lambda c:f'=AND(NOT(ISBLANK(INDIRECT(ADDRESS(ROW(),COLUMN())))),LEN(TRIM(INDIRECT(ADDRESS(ROW(),COLUMN()))))>0,{c})'
    rules=[
        (f'{ve}=0',                       {"red":1,"green":0.6,"blue":0.6}),
        (f'{ve}>=300',                     {"red":0.6,"green":1,"blue":1}),
        (f'AND({ve}>=200,{ve}<300)',       {"red":0.7,"green":1,"blue":0.7}),
        (f'AND({ve}>=100,{ve}<200)',       {"red":1,"green":1,"blue":0.6}),
        (f'AND({ve}<100,{ve}>0)',          {"red":1,"green":0.8,"blue":0.8}),
    ]
    cr=[{"addConditionalFormatRule":{"rule":{"ranges":[{"sheetId":sid,"startRowIndex":1,"endRowIndex":tdr,"startColumnIndex":3,"endColumnIndex":nc}],"booleanRule":{"condition":{"type":"CUSTOM_FORMULA","values":[{"userEnteredValue":rf(c)}]},"format":{"backgroundColor":bg}}},"index":0}} for c,bg in rules]
    with_retry(ss.batch_update, body={"requests":cr}); time.sleep(3)

    print("  🎨 텍스트 색상...")
    txr=[]
    for ci in range(3,nc):
        try: cv=with_retry(ws.col_values,ci+1)
        except: continue
        if not cv or len(cv)<2: continue
        for ri in range(1,min(len(cv),tdr)):
            val=cv[ri]
            if not val or '\n' not in val: continue
            lines=val.split('\n')
            if len(lines)<3: continue
            l1e=len(lines[0]); l2e=l1e+1+len(lines[1]); l3e=l2e+1+len(lines[2])
            runs=[{"startIndex":0,"format":BK},{"startIndex":l1e+1,"format":GN},{"startIndex":l2e+1,"format":BK}]
            if len(lines)>=4: runs.append({"startIndex":l3e+1,"format":RD})
            txr.append({"updateCells":{"range":{"sheetId":sid,"startRowIndex":ri,"endRowIndex":ri+1,"startColumnIndex":ci,"endColumnIndex":ci+1},"rows":[{"values":[{"userEnteredValue":{"stringValue":val},"textFormatRuns":runs}]}],"fields":"userEnteredValue,textFormatRuns"}})
            if len(txr)>=300:
                try: with_retry(ss.batch_update,body={"requests":txr}); txr=[]; time.sleep(3)
                except: txr=[]
    if txr:
        try: with_retry(ss.batch_update,body={"requests":txr}); time.sleep(2)
        except: pass

    print(f"\n  ✅ '{SHEET_NAME}' 완성!")

