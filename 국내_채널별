    try:
        retry_batch_update(sp, body={"requests":fr})
        time.sleep(3)
        print("  ✅ 기본+조건부 서식")
    except Exception as e:
        print(f"  ⚠️ 기본서식 실패 (계속 진행): {e}")

    try:
        lines = C2_LABEL.split('\n')
