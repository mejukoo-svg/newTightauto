def df_to_vals(df):
    data = [MASTER_HEADERS]
    for _, r in df.iterrows():
        data.append([clean_for_json(r.get(h, '')) for h in MASTER_HEADERS])
    return data

def write_master(sp, df):
    from gspread_formatting import CellFormat, TextFormat, Color, format_cell_range, set_frozen, set_column_width

    try: ws = sp.worksheet(MASTER_TAB); ws.clear()
    except gspread.WorksheetNotFound:
        ws = sp.add_worksheet(title=MASTER_TAB, rows=max(len(df)+10,100), cols=20)

    vals = df_to_vals(df)
    retry_api(ws.update, range_name='A1', values=vals)
    print(f"✅ 마스터탭: {len(vals)-1}행")

    retry_api(format_cell_range, ws, '1:1',
        CellFormat(textFormat=TextFormat(bold=True, fontFamily='Arial'),
                   backgroundColor=Color(0.898, 0.898, 0.898)))

    if len(vals) > 1:
        retry_api(format_cell_range, ws, f'2:{len(vals)}',
            CellFormat(textFormat=TextFormat(fontFamily='Arial')))

    for c, w in {'A':100,'B':180,'C':180,'D':120,'E':130,'F':80,'G':80,
                 'H':70,'I':100,'J':100,'K':100,'L':100,'M':70,'N':70}.items():
        retry_api(set_column_width, ws, c, w)

    retry_api(set_frozen, ws, rows=1)

    nf = CellFormat(numberFormat={'type':'NUMBER','pattern':'#,##0'})
    pf = CellFormat(numberFormat={'type':'NUMBER','pattern':'#,##0.0#'})
    if len(vals) > 1:
        for c in ['E','F','G','I','J','K','L']:
            retry_api(format_cell_range, ws, f'{c}2:{c}{len(vals)}', nf)
        for c in ['H','M','N']:
            retry_api(format_cell_range, ws, f'{c}2:{c}{len(vals)}', pf)

    time.sleep(1)
    print("  ✅ 마스터탭 서식 완료")

def write_trend(sp, df):
    try: ws = sp.worksheet(TREND_TAB); ws.clear()
    except gspread.WorksheetNotFound:
        ws = sp.add_worksheet(title=TREND_TAB, rows=5000, cols=200)
    sid = ws.id
    dates = sorted(df['Date'].unique(), reverse=True)
    wd = {0:'월',1:'화',2:'수',3:'목',4:'금',5:'토',6:'일'}

    def dh(d):
        dt=datetime.strptime(d,'%Y-%m-%d'); return f"{dt.strftime('%y/%m/%d')}({wd[dt.weekday()]})"

    def ct(cost, rev, clk, conv):
        if cost==0 and clk==0 and rev==0: return ""
        if cost>0: roas=int(round(rev/cost*100))
        elif rev>0: roas="∞"
        else: roas=0
        pf = rev-cost
        cvr = round(conv/clk*100,1) if clk>0 else 0
        pf_s = f"₩{pf:,.0f}" if pf>=0 else f"-₩{abs(pf):,.0f}"
        rev_s = f"₩{rev:,.0f}"
        return f"{roas}\n{pf_s}\n-₩{cost:,.0f}\n{rev_s}\n{cvr}%"

    C2_LABEL = "ROAS\n순이익\n지출\n매출\n전환율"
    sun_cols = []
    date_hdrs = []
    for i,d in enumerate(dates):
        date_hdrs.append(dh(d))
        if datetime.strptime(d,'%Y-%m-%d').weekday()==6: sun_cols.append(4+i)

    header = ['캠페인','광고그룹','키워드','7일 평균'] + date_hdrs
    daily = df.groupby('Date').agg({
        '총비용(VAT포함,원)':'sum','매출':'sum','클릭수':'sum','결과(믹스패널)':'sum'
    }).to_dict('index')

    r7 = dates[:7]
    t = lambda k: sum(daily.get(d,{}).get(k,0) for d in r7)
    total_row = ['종합','',C2_LABEL, ct(t('총비용(VAT포함,원)'),t('매출'),t('클릭수'),t('결과(믹스패널)'))]
    for d in dates:
        dd=daily.get(d,{})
        total_row.append(ct(dd.get('총비용(VAT포함,원)',0),dd.get('매출',0),dd.get('클릭수',0),dd.get('결과(믹스패널)',0)))

    kw_grp = df.groupby(['캠페인','광고그룹','키워드'])
    kw_d = {}
    for (c,a,k),grp in kw_grp:
        kw_d[(c,a,k)]={r['Date']:{'cost':r['총비용(VAT포함,원)'],'rev':r['매출'],'clk':r['클릭수'],'conv':r['결과(믹스패널)']} for _,r in grp.iterrows()}

    kw_s = sorted(kw_d.items(), key=lambda x:sum(x[1].get(d,{}).get('cost',0) for d in r7), reverse=True)
    all_rows = [header, total_row]
    for (c,a,k),dm in kw_s:
        row=[c,a,k]
        c7=sum(dm.get(d,{}).get('cost',0) for d in r7)
        r7v=sum(dm.get(d,{}).get('rev',0) for d in r7)
        k7=sum(dm.get(d,{}).get('clk',0) for d in r7)
        v7=sum(dm.get(d,{}).get('conv',0) for d in r7)
        row.append(ct(c7,r7v,k7,v7) if c7>0 or k7>0 or r7v>0 else '')
        for d in dates:
            dd=dm.get(d)
            row.append(ct(dd['cost'],dd['rev'],dd['clk'],dd['conv']) if dd and (dd['cost']>0 or dd['clk']>0 or dd['rev']>0) else '')
        all_rows.append(row)

    retry_api(ws.update, range_name='A1', values=all_rows)
    rc=len(all_rows); nc=len(header)
    print(f"✅ 추이차트: {rc-1}행 × {nc}열")

    print("  🎨 서식...")
    fr = []
    fr.append({"repeatCell":{"range":{"sheetId":sid,"startRowIndex":0,"endRowIndex":1,"startColumnIndex":0,"endColumnIndex":nc},
        "cell":{"userEnteredFormat":{"backgroundColor":{"red":0.9,"green":0.9,"blue":0.9},"textFormat":{"bold":True,"fontFamily":"Arial"}}},"fields":"userEnteredFormat"}})
    fr.append({"repeatCell":{"range":{"sheetId":sid,"startRowIndex":1,"endRowIndex":2,"startColumnIndex":0,"endColumnIndex":nc},
        "cell":{"userEnteredFormat":{"textFormat":{"bold":True,"fontFamily":"Arial"}}},"fields":"userEnteredFormat.textFormat"}})
    for ci in sun_cols:
        if ci<nc:
            fr.append({"repeatCell":{"range":{"sheetId":sid,"startRowIndex":0,"endRowIndex":1,"startColumnIndex":ci,"endColumnIndex":ci+1},
                "cell":{"userEnteredFormat":{"backgroundColor":{"red":1.0,"green":0.85,"blue":0.85},"textFormat":{"bold":True}}},"fields":"userEnteredFormat"}})
    fr.append({"updateSheetProperties":{"properties":{"sheetId":sid,"gridProperties":{"frozenRowCount":1}},"fields":"gridProperties.frozenRowCount"}})
    fr.append({"repeatCell":{"range":{"sheetId":sid,"startRowIndex":1,"endRowIndex":rc,"startColumnIndex":3,"endColumnIndex":nc},
        "cell":{"userEnteredFormat":{"wrapStrategy":"WRAP","verticalAlignment":"TOP","textFormat":{"fontFamily":"Arial","fontSize":9}}},"fields":"userEnteredFormat"}})
    fr.append({"updateDimensionProperties":{"range":{"sheetId":sid,"dimension":"COLUMNS","startIndex":0,"endIndex":1},"properties":{"pixelSize":180},"fields":"pixelSize"}})
    fr.append({"updateDimensionProperties":{"range":{"sheetId":sid,"dimension":"COLUMNS","startIndex":1,"endIndex":2},"properties":{"pixelSize":200},"fields":"pixelSize"}})
    fr.append({"updateDimensionProperties":{"range":{"sheetId":sid,"dimension":"COLUMNS","startIndex":2,"endIndex":3},"properties":{"pixelSize":120},"fields":"pixelSize"}})
    for ci in range(3, min(nc, 200)):
        fr.append({"updateDimensionProperties":{"range":{"sheetId":sid,"dimension":"COLUMNS","startIndex":ci,"endIndex":ci+1},"properties":{"pixelSize":95},"fields":"pixelSize"}})
    fr.append({"updateDimensionProperties":{"range":{"sheetId":sid,"dimension":"ROWS","startIndex":1,"endIndex":rc},"properties":{"pixelSize":85},"fields":"pixelSize"}})

    roas_rules = [
        ('=AND(NOT(ISBLANK(INDIRECT(ADDRESS(ROW(),COLUMN())))),LEN(TRIM(INDIRECT(ADDRESS(ROW(),COLUMN()))))>0,VALUE(LEFT(INDIRECT(ADDRESS(ROW(),COLUMN())),FIND(CHAR(10),INDIRECT(ADDRESS(ROW(),COLUMN()))&CHAR(10))-1))=0)',
         {'red':1.0,'green':0.6,'blue':0.6}),
        ('=AND(NOT(ISBLANK(INDIRECT(ADDRESS(ROW(),COLUMN())))),LEN(TRIM(INDIRECT(ADDRESS(ROW(),COLUMN()))))>0,VALUE(LEFT(INDIRECT(ADDRESS(ROW(),COLUMN())),FIND(CHAR(10),INDIRECT(ADDRESS(ROW(),COLUMN()))&CHAR(10))-1))>=300)',
         {'red':0.6,'green':1.0,'blue':1.0}),
        ('=AND(NOT(ISBLANK(INDIRECT(ADDRESS(ROW(),COLUMN())))),LEN(TRIM(INDIRECT(ADDRESS(ROW(),COLUMN()))))>0,VALUE(LEFT(INDIRECT(ADDRESS(ROW(),COLUMN())),FIND(CHAR(10),INDIRECT(ADDRESS(ROW(),COLUMN()))&CHAR(10))-1))>=200,VALUE(LEFT(INDIRECT(ADDRESS(ROW(),COLUMN())),FIND(CHAR(10),INDIRECT(ADDRESS(ROW(),COLUMN()))&CHAR(10))-1))<300)',
         {'red':0.7,'green':1.0,'blue':0.7}),
        ('=AND(NOT(ISBLANK(INDIRECT(ADDRESS(ROW(),COLUMN())))),LEN(TRIM(INDIRECT(ADDRESS(ROW(),COLUMN()))))>0,VALUE(LEFT(INDIRECT(ADDRESS(ROW(),COLUMN())),FIND(CHAR(10),INDIRECT(ADDRESS(ROW(),COLUMN()))&CHAR(10))-1))>=100,VALUE(LEFT(INDIRECT(ADDRESS(ROW(),COLUMN())),FIND(CHAR(10),INDIRECT(ADDRESS(ROW(),COLUMN()))&CHAR(10))-1))<200)',
         {'red':1.0,'green':1.0,'blue':0.6}),
        ('=AND(NOT(ISBLANK(INDIRECT(ADDRESS(ROW(),COLUMN())))),LEN(TRIM(INDIRECT(ADDRESS(ROW(),COLUMN()))))>0,VALUE(LEFT(INDIRECT(ADDRESS(ROW(),COLUMN())),FIND(CHAR(10),INDIRECT(ADDRESS(ROW(),COLUMN()))&CHAR(10))-1))<100,VALUE(LEFT(INDIRECT(ADDRESS(ROW(),COLUMN())),FIND(CHAR(10),INDIRECT(ADDRESS(ROW(),COLUMN()))&CHAR(10))-1))>0)',
         {'red':1.0,'green':0.8,'blue':0.8}),
