def _fetch_trend_row2(gc, url, gid, label, line_config):
    print(f"\n" + "="*60)
    print(f"📊 [{label}]")
    print("="*60)

    ss = gc.open_by_url(url)
    ws = None
    for s in ss.worksheets():
        if s.id == gid: ws = s; break
    if ws is None:
        for s in ss.worksheets():
            if '추이차트' in s.title and '주간' not in s.title: ws = s; break
    if ws is None: print("  ⚠️ 추이차트 탭 못 찾음"); return {}

    print(f"  📖 시트: {ws.title}")
    vals = with_retry(ws.get_all_values); time.sleep(1)
    if not vals or len(vals) < 2: print("  ⚠️ 빈 시트"); return {}

    headers = vals[0]
    row2 = vals[1]

    print(f"  → 전체 컬럼 수: {len(headers)}")
    for ci in range(min(8, len(headers))):
        h_repr = repr(headers[ci])
        print(f"    col{ci}: {h_repr}")

    date_start_col = None
    for ci in range(len(headers)):
        dt = parse_date(headers[ci])
        if dt is not None:
            date_start_col = ci
            print(f"  → 날짜 시작: col{ci} = {repr(headers[ci])} → {dt}")
            break

    if date_start_col is None:
        print("  ⚠️ 날짜 컬럼 못 찾음!")
        print(f"  → 헤더 전체: {[repr(h) for h in headers[:15]]}")
        return {}

    first_cell = str(row2[date_start_col]) if date_start_col < len(row2) else ""
    first_lines = first_cell.split('\n')
    print(f"  → 파싱 모드: {line_config}")
    print(f"  → 첫 셀 (col{date_start_col}) 라인수={len(first_lines)}:")
    for li, l in enumerate(first_lines):
        print(f"    line[{li}] = {repr(l)}")

    start_d = datetime.strptime(START_DATE,"%Y-%m-%d").date()
    end_d = datetime.strptime(END_DATE,"%Y-%m-%d").date()
    daily = {}
    parsed_count = 0
    skip_count = 0

    for ci in range(date_start_col, len(headers)):
        dt = parse_date(headers[ci])
        if dt is None:
            skip_count += 1
            continue
        if dt < start_d or dt > end_d:
            continue

        cell = str(row2[ci]) if ci < len(row2) else ""
        if not cell.strip():
            continue

        lines = [l.strip() for l in cell.split('\n')]

        if line_config == 'meta':
            raw_spend = _num(lines[2]) if len(lines) > 2 else 0
            spend = abs(raw_spend)
            profit = _num(lines[1]) if len(lines) > 1 else 0
            revenue = spend + profit
        elif line_config == 'vanced':
            revenue = abs(_num(lines[2])) if len(lines) > 2 else 0
            raw_spend = _num(lines[3]) if len(lines) > 3 else 0
            spend = abs(raw_spend)

            if spend == 0 and len(lines) <= 3 and len(lines) > 1:
                profit = _num(lines[1])
                spend = max(revenue - profit, 0) if revenue > 0 else 0
        else:
            continue

        if parsed_count < 3:
            print(f"  → {dt}: lines={[repr(l) for l in lines[:5]]} → spend={spend:.0f}, rev={revenue:.0f}")

        if spend > 0 or revenue > 0:
            daily[dt] = {'spend': spend, 'revenue': max(revenue, 0)}
            parsed_count += 1

    if skip_count > 0:
        print(f"  → 날짜 파싱 실패 {skip_count}건 (7일평균 등 비날짜 컬럼)")

    ts = sum(d['spend'] for d in daily.values())
    tr = sum(d['revenue'] for d in daily.values())
    for dt in sorted(daily):
        sp, rv = daily[dt]['spend'], daily[dt]['revenue']
        pf = rv - sp
        if sp > 0:
            print(f"  {dt}  지출 ₩{sp:>12,.0f}  순이익 ₩{pf:>12,.0f}  매출 ₩{rv:>12,.0f}  ROAS {rv/sp*100:.0f}%")
        else:
            print(f"  {dt}  매출 ₩{rv:>12,.0f}")
    if ts > 0:
        print(f"  합계   지출 ₩{ts:>12,.0f}  매출 ₩{tr:>12,.0f}  ROAS {tr/ts*100:.0f}%")
    print(f"  → {len(daily)}일 데이터")
    return daily

