def money(n):
    try: return f"₩{int(round(float(n))):,}"
    except: return "₩0"

def cell_text(revenue, spend):
    if spend == 0 and revenue == 0: return ""
    roas = (revenue / spend * 100) if spend > 0 else 0
    profit = revenue - spend
    return f"{roas:.0f}\n{money(profit)}\n{money(revenue)}\n-{money(spend)}"

def _num(x):
    try:
        v = str(x).replace(",","").replace("₩","").replace("%","").replace("\\","").replace("W","").replace("￦","").replace("+","").strip()
        return float(v) if v and v not in ["-","#DIV/0!","","nan","None","NaN"] else 0.0
    except: return 0.0

def with_retry(fn, *a, max_retries=5, **kw):
    for i in range(max_retries):
        try: return fn(*a, **kw)
        except Exception as e:
            if "429" in str(e) or "Quota" in str(e): time.sleep(15+i*10)
            elif i==max_retries-1: raise
            else: time.sleep(3)

def parse_date(raw):
    raw = str(raw).strip()
    if not raw or raw in ['', 'nan', 'None']: return None
    raw = raw.split('\n')[0].strip()

    m = re.match(r'^(\d{2})/(\d{1,2})/(\d{1,2})', raw)
    if m:
        try: return date(2000 + int(m.group(1)), int(m.group(2)), int(m.group(3)))
        except: pass

    m = re.match(r'^(\d{1,2})/(\d{1,2})\s+\(', raw)
    if m:
        month, day = int(m.group(1)), int(m.group(2))
        year = 2026 if month <= 3 else 2025
        try: return date(year, month, day)
        except: return None

    m = re.match(r'^(\d{1,2})/(\d{1,2})(?:\s*$|\s*[\(\[])', raw)
    if m:
        month, day = int(m.group(1)), int(m.group(2))
        year = 2026 if month <= 3 else 2025
        try: return date(year, month, day)
        except: return None

    m = re.match(r'^(\d{2})-(\d{1,2})-(\d{1,2})$', raw)
    if m:
        try: return date(2000 + int(m.group(1)), int(m.group(2)), int(m.group(3)))
        except: return None

    m = re.match(r'^(\d{2})/(\d{1,2})/(\d{1,2})$', raw)
    if m:
        try: return date(2000 + int(m.group(1)), int(m.group(2)), int(m.group(3)))
        except: return None

    for fmt in ["%Y-%m-%d %H:%M:%S", "%Y-%m-%d", "%Y/%m/%d"]:
        try: return datetime.strptime(raw[:19 if 'H' in fmt else 10], fmt).date()
        except: pass

    return None

def fmt_req(sid,sr,er,sc,ec,fmt):
    return {"repeatCell":{"range":{"sheetId":sid,"startRowIndex":sr,"endRowIndex":er,"startColumnIndex":sc,"endColumnIndex":ec},"cell":{"userEnteredFormat":fmt},"fields":"userEnteredFormat"}}

def border_req(sid,sr,er,sc,ec):
    bs={"style":"SOLID","width":1,"color":{"red":0.7,"green":0.7,"blue":0.7}}
    return {"updateBorders":{"range":{"sheetId":sid,"startRowIndex":sr,"endRowIndex":er,"startColumnIndex":sc,"endColumnIndex":ec},"top":bs,"bottom":bs,"left":bs,"right":bs,"innerHorizontal":bs,"innerVertical":bs}}

