def detect_landing_events(sample_date):
    print(f"\n🔎 랜딩 이벤트명 자동 탐지 ({sample_date})...")
    hdrs = mp_auth_header()

    s_dt = datetime.strptime(sample_date, '%Y-%m-%d')
    sample_from = (s_dt - timedelta(days=2)).strftime('%Y-%m-%d')

    found = {}

    def probe_event(event_name):
        try:
            r = requests.get(MP_EXPORT_URL, headers=hdrs, timeout=60,
                params={
                    'project_id': MIXPANEL_PROJECT_ID,
                    'from_date': sample_from, 'to_date': sample_date,
                    'event': json.dumps([event_name])
                }, stream=True)
            if r.status_code != 200: return (event_name, 0, 0)
            total = 0; nsa = 0
            for line in r.iter_lines(decode_unicode=True):
                if not line or not line.strip(): continue
                total += 1
                if total > 5000: break
                try:
                    p = json.loads(line).get('properties', {})
                    ch = str(p.get('ch', '')).lower().strip()
                    ct = str(p.get('ct', '')).lower().strip()
                    src = str(p.get('utm_source', p.get('$source', ''))).lower()
                    med = str(p.get('utm_medium', p.get('$medium', ''))).lower()
                    if (ch == 'naver' and 'nsa' in ct) or \
                       ('naver' in src and ('nsa' in med or 'cpc' in med or 'paid' in med)):
                        nsa += 1
                except: continue
            r.close()
            return (event_name, total, nsa)
        except:
            return (event_name, 0, 0)

    print(f"  후보 {len(LANDING_CANDIDATES)}개 탐색 (병렬 {MP_WORKERS}스레드)...")
    with ThreadPoolExecutor(max_workers=MP_WORKERS) as executor:
        futures = {executor.submit(probe_event, name): name for name in LANDING_CANDIDATES}
        for f in as_completed(futures):
            name, total, nsa = f.result()
            if total > 0:
                print(f"    '{name}' → 전체 {total:,}건, NSA {nsa}건", "✅" if nsa > 0 else "")
            if nsa > 0:
                found[name] = nsa

    if found:
        sorted_found = sorted(found.items(), key=lambda x: x[1], reverse=True)
        print(f"\n  ✅ 네이버SA 랜딩 이벤트 확인:")
        for name, cnt in sorted_found:
            print(f"    '{name}' → NSA {cnt}건")
        return [name for name, _ in sorted_found]
    else:
        print(f"\n  ⚠️ 후보 {len(LANDING_CANDIDATES)}개 중 NSA UTM이 붙은 이벤트 없음.")
        print("     가능한 원인:")
        print("     1) 페이지뷰 이벤트에 ch/ct 또는 utm 프로퍼티가 전달되지 않음")
        print("     2) 이벤트명이 후보 목록에 없음 (믹스패널에서 확인 필요)")
        print("     → 랜딩 데이터 없이 기존 방식으로 진행합니다.")
        return []


# ── 네이버SA 랜딩 세션 수집 ──
def collect_sa_landings(from_d, to_d):
    print(f"\n🔍 네이버SA 랜딩 세션 수집 ({from_d} ~ {to_d})...")
    print(f"  이벤트: {LANDING_EVENTS}")
    print(f"  세션 윈도우: {SESSION_WINDOW_SEC}초 ({SESSION_WINDOW_SEC//60}분)")

    chunks = make_mp_chunks(from_d, to_d)
    print(f"  {len(chunks)}청크, 병렬 {MP_WORKERS}스레드")

    lock = threading.Lock()
    stats = {'total': 0, 'matched': 0, 'done': 0}

    def fetch_landing_chunk(chunk):
        cs, ce = chunk
        hdrs = mp_auth_header()
        local_events = []
        try:
            r = requests.get(MP_EXPORT_URL, headers=hdrs, timeout=300,
                params={
                    'project_id': MIXPANEL_PROJECT_ID,
                    'from_date': cs, 'to_date': ce,
                    'event': json.dumps(LANDING_EVENTS)
                })
            if r.status_code != 200:
                return local_events
            for line in r.text.strip().split('\n'):
                if not line.strip(): continue
                try:
                    p = json.loads(line).get('properties', {})
                    ch = str(p.get('ch', '')).lower().strip()
                    ct = str(p.get('ct', '')).lower().strip()
                    if ch != 'naver' or 'nsa' not in ct: continue
                    did = str(p.get('distinct_id', ''))
                    ts = int(p.get('time', 0))
                    if did and ts > 0:
                        local_events.append((did, ts))
                except: continue
        except: pass
        with lock:
            stats['done'] += 1
            stats['matched'] += len(local_events)
            if stats['done'] % 3 == 0 or stats['done'] == len(chunks):
                print(f"    청크 {stats['done']}/{len(chunks)} 완료 (SA랜딩 {stats['matched']:,}건)")
        return local_events

    all_events = []
    with ThreadPoolExecutor(max_workers=MP_WORKERS) as executor:
        futures = [executor.submit(fetch_landing_chunk, c) for c in chunks]
        for f in as_completed(futures):
            all_events.extend(f.result())

    sa_sessions = defaultdict(list)
    for did, ts in all_events:
        sa_sessions[did].append(ts)
    for did in sa_sessions:
        sa_sessions[did].sort()

    unique_users = len(sa_sessions)
    total_landings = sum(len(v) for v in sa_sessions.values())
    print(f"  ✅ SA 랜딩 {total_landings:,}건, 유니크 유저 {unique_users:,}명")

    if total_landings == 0:
        print(f"\n  ⚠️ 랜딩 이벤트 0건! LANDING_EVENTS를 확인하세요.")
        print(f"     현재 설정: {LANDING_EVENTS}")
        print(f"     → 믹스패널 이벤트 목록에서 실제 페이지뷰 이벤트명을 확인 후 수정 필요")
        print(f"     → 랜딩 데이터 없이 기존 방식(전체 귀속)으로 진행합니다.\n")

    return dict(sa_sessions)


# ── 믹스패널 결제 수집 + 세션 매칭 ──
def get_mixpanel(from_d, to_d, sa_sessions=None):
    print(f"\n💰 믹스패널 결제 수집 ({from_d} ~ {to_d})...")
    print(f"  결제 이벤트명: {PAYMENT_EVENTS}")

    INVALID_CR = {'vanced', '{keyword}', '{keword}', ''}
    chunks = make_mp_chunks(from_d, to_d)
    print(f"  {len(chunks)}청크, 병렬 {MP_WORKERS}스레드")

    lock = threading.Lock()
    stats = {'total': 0, 'nsa_matched': 0, 'skipped_invalid': 0, 'done': 0}

    def fetch_payment_chunk(chunk):
        cs, ce = chunk
        hdrs = mp_auth_header()
        local_events = []
        local_total = 0
        local_skip = 0
        try:
            r = requests.get(MP_EXPORT_URL, headers=hdrs, timeout=300,
                params={
                    'project_id': MIXPANEL_PROJECT_ID,
                    'from_date': cs, 'to_date': ce,
                    'event': json.dumps(PAYMENT_EVENTS)
                })
            if r.status_code != 200:
                return local_events, local_total, local_skip
            for line in r.text.strip().split('\n'):
                if not line.strip(): continue
                try:
                    p = json.loads(line).get('properties', {})
                    local_total += 1
                    ch = str(p.get('ch', '')).lower().strip()
                    ct = str(p.get('ct', '')).lower().strip()
                    cr = str(p.get('cr', '')).strip()
                    if ch != 'naver' or 'nsa' not in ct: continue
                    if cr in INVALID_CR or cr.startswith('{'):
                        local_skip += 1; continue
                    amt = safe_float(p.get('amount', 0))
                    val = safe_float(p.get('value', 0))
                    rev = amt if amt > 0 else (val if val > 0 else 0)
                    ts = int(p.get('time', 0))
                    dt = datetime.fromtimestamp(ts, tz=KST).strftime('%Y-%m-%d')
                    did = str(p.get('distinct_id', ''))
                    svc = str(p.get('서비스', ''))
                    local_events.append({
                        'date': dt, 'cr': cr, 'revenue': rev,
                        'did': did, 'svc': svc, 'ts': ts
                    })
                except: continue
        except: pass
        with lock:
            stats['done'] += 1
            stats['nsa_matched'] += len(local_events)
            stats['total'] += local_total
            stats['skipped_invalid'] += local_skip
            if stats['done'] % 3 == 0 or stats['done'] == len(chunks):
                print(f"    청크 {stats['done']}/{len(chunks)} (NSA {stats['nsa_matched']:,}건)")
        return local_events, local_total, local_skip

    raw_events = []
    with ThreadPoolExecutor(max_workers=MP_WORKERS) as executor:
        futures = [executor.submit(fetch_payment_chunk, c) for c in chunks]
        for f in as_completed(futures):
            events, _, _ = f.result()
            raw_events.extend(events)

    if stats['skipped_invalid'] > 0:
        print(f"\n  🚫 무효 cr 스킵: {stats['skipped_invalid']}건")

    print(f"\n  🔄 중복 제거... (원본: {len(raw_events)}건)")
    if not raw_events:
        print(f"  ⚠️ 매칭 없음")
        return defaultdict(lambda: defaultdict(lambda: {'revenue':0,'count':0}))

    df_r = pd.DataFrame(raw_events)
    df_r = df_r.sort_values('revenue', ascending=False)
    before = len(df_r)
    df_r = df_r.drop_duplicates(subset=['date', 'did', 'svc'], keep='first')
    print(f"  ✅ {before} → {len(df_r)}건 ({before - len(df_r)}건 제거)")

    # ★★★ 세션 매칭 필터링 ★★★
    has_sessions = sa_sessions and len(sa_sessions) > 0

    if has_sessions:
        print(f"\n  🎯 세션 매칭 (윈도우: {SESSION_WINDOW_SEC//60}분)...")

        def is_within_session(row):
            did = row['did']
            pay_ts = row['ts']
            if did not in sa_sessions:
                return False
            landings = sa_sessions[did]
            idx = bisect.bisect_right(landings, pay_ts)
            if idx > 0:
                closest_before = landings[idx - 1]
                if 0 <= (pay_ts - closest_before) <= SESSION_WINDOW_SEC:
                    return True
            return False

        df_r['session_match'] = df_r.apply(is_within_session, axis=1)
        direct   = df_r[df_r['session_match'] == True]
        indirect = df_r[df_r['session_match'] == False]

        print(f"    ✅ 직접 전환 (세션 내): {len(direct)}건, ₩{direct['revenue'].sum():,.0f}")
        print(f"    ⚠️ 간접 전환 (세션 외): {len(indirect)}건, ₩{indirect['revenue'].sum():,.0f}")
        print(f"    📊 직접 전환 비율: {len(direct)/len(df_r)*100:.1f}%")

        df_use = direct.copy()
        print(f"\n  → 직접 전환만 매출에 반영합니다.")
    else:
        print(f"\n  ⚠️ 랜딩 세션 데이터 없음 → 기존 방식(전체 귀속)으로 진행")
        df_use = df_r.copy()

    revenue = defaultdict(lambda: defaultdict(lambda: {'revenue': 0, 'count': 0}))
    for _, row in df_use.iterrows():
        revenue[row['cr']][row['date']]['revenue'] += row['revenue']
        revenue[row['cr']][row['date']]['count'] += 1

    cr_totals = {}
    for cr in revenue:
        t_rev = sum(d['revenue'] for d in revenue[cr].values())
        t_cnt = sum(d['count'] for d in revenue[cr].values())
        cr_totals[cr] = (t_rev, t_cnt)
    top20 = sorted(cr_totals.items(), key=lambda x: x[1][0], reverse=True)[:20]
    label = "직접전환" if has_sessions else "전체"
    print(f"\n  고유 cr {len(revenue)}개 — {label} 기준 (상위 20):")
    for cr, (rev, cnt) in top20:
        print(f"    '{cr}' → ₩{rev:,.0f} ({cnt}건)")

    return revenue


# ── 병합 ──
def merge(df_naver, rev_data):
    print("\n🔄 병합...")
    nkw = set(df_naver['키워드'].unique()) if len(df_naver) else set()
    mcr = set(rev_data.keys())
    matched = nkw & mcr
    print(f"  네이버 {len(nkw)}개 / 믹스패널 {len(mcr)}개 / 매칭 {len(matched)}개")
    if mcr - nkw:
        print(f"  ⚠️ 미매칭: {sorted(mcr-nkw)[:15]}...")

    rl, cl = [], []
    for _, row in df_naver.iterrows():
        d = rev_data.get(row['키워드'], {}).get(row['Date'], {})
        rl.append(d.get('revenue', 0)); cl.append(d.get('count', 0))

    df = df_naver.copy()
    df['결과(믹스패널)'] = cl
    df['매출'] = rl
    df['이익'] = df['매출'] - df['총비용(VAT포함,원)']
    df['ROAS'] = df.apply(lambda r:
        round(r['매출']/r['총비용(VAT포함,원)']*100, 1) if r['총비용(VAT포함,원)'] > 0
        else ('∞' if r['매출'] > 0 else 0), axis=1)
    df['CVR(%)'] = df.apply(lambda r:
        round(r['결과(믹스패널)']/r['클릭수']*100, 2) if r['클릭수'] > 0 else 0, axis=1)

    print(f"✅ {len(df)}건, 비용 ₩{df['총비용(VAT포함,원)'].sum():,.0f}, 매출 ₩{df['매출'].sum():,.0f}")
    return df


